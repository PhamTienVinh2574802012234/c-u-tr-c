def find_boundary(a, x, find_first):
    low, high = 0, len(a) - 1
    result = -1
    while low <= high:
        mid = (low + high) // 2
        if a[mid] == x:
            result = mid
            if find_first:
                high = mid - 1
            else:
                low = mid + 1
        elif a[mid] < x:
            low = mid + 1
        else:
            high = mid - 1
    return result
def count_occurrences_custom(a, x):
    first = find_boundary(a, x, find_first=True)
    if first == -1:
        return 0
    last = find_boundary(a, x, find_first=False)
    return last - first + 1