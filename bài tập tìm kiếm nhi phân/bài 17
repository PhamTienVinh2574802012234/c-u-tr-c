def shipWithinDays(weights: list[int], days: int) -> int:
    low, high = max(weights), sum(weights)
    while low < high:
        mid = (low + high) // 2
        days_needed, current_load = 1, 0
        for w in weights:
            if current_load + w > mid:
                days_needed += 1
                current_load = 0
            current_load += w
        if days_needed <= days:
            high = mid
        else:
            low = mid + 1 
    return low