def find_first_occurrence(a, x):
    left, right = 0, len(a) - 1
    ans = -1
    while left <= right:
        mid = left + (right - left) // 2
        if a[mid] == x:
            ans = mid
            right = mid - 1
            left = mid + 1
        else:
            right = mid - 1
    return ans