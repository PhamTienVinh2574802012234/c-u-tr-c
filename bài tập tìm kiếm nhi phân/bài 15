import bisect
def find_closest_elements(arr: list[int], k: int, x: int) -> list[int]:
    right = bisect.bisect_left(arr, x)
    left = right - 1
    for _ in range(k):
        if left < 0:
            right += 1
        elif right >= len(arr):
            left -= 1
        else:
            if abs(arr[left] - x) <= abs(arr[right] - x):
                left -= 1
            else:
                right += 1
    return arr[left + 1 : right]