def minEatingSpeed(piles, h):
    left, right = 1, max(piles)
    while left < right:
        mid = (left + right) // 2
        total_hours = sum((p + mid - 1) // mid for p in piles)
        if total_hours <= h:
            right = mid
        else:
            left = mid + 1
    return left
print(minEatingSpeed([3, 6, 7, 11], 8))