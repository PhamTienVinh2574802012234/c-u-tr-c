def count_bubble_sort_passes(a):
    n = len(a)
    pass_count = 0
    for i in range(n):
        swapped = False
        pass_count += 1
        for j in range(0, n - i - 1):
            if a[j] > a[j + 1]:
                a[j], a[j + 1] = a[j + 1], a[j]
                swapped = True
        if not swapped:
            break        
    return pass_count