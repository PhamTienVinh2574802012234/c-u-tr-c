def bubble_sort(a):
    n = len(a)
    for i in range(n - 1):
        swapped = False
        for j in range(0, n - i - 1):
            if a[j] > a[j + 1]:
                a[j], a[j + 1] = a[j + 1], a[j]
                swapped = True
        if not swapped:
            break
if __name__ == "__main__":
    a = list(map(int, input("Nhap các phan tu (cach nhau boi dau cach): ").split()))
    bubble_sort(a)
    print("Mang sau khi sap xep:", a)