def tim_max_va_vi_tri(mang):
    if not mang:
        return None, None
    max_val = mang[0]
    max_idx = 0
    for i in range(1, len(mang)):
        if mang[i] > max_val:
            max_val = mang[i]
            max_idx = i
    return max_val, max_idx
mang_so = [10, 25, 4, 99, 32, 8]
gia_tri, vi_tri = tim_max_va_vi_tri(mang_so)
print(f"Mảng: {mang_so}")
print(f"Giá trị lớn nhất: {gia_tri}")
print(f"Vị trí (chỉ số bắt đầu từ 0): {vi_tri}")